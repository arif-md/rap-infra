{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "acrName": {
        "value": "${AZURE_ACR_NAME}"
      },
      "acrResourceGroupOverride": {
        "value": "${AZURE_ACR_RESOURCE_GROUP}"
      },
      "skipFrontendAcrPullRoleAssignment": {
        "value": "${SKIP_FRONTEND_ACR_PULL_ROLE_ASSIGNMENT=true}"
      },
      "skipBackendAcrPullRoleAssignment": {
        "value": "${SKIP_BACKEND_ACR_PULL_ROLE_ASSIGNMENT=true}"
      },
      "frontendImage": {
        "value": "${SERVICE_FRONTEND_IMAGE_NAME}"
      },
      "backendImage": {
        "value": "${SERVICE_BACKEND_IMAGE_NAME}"
      },
      "processesImage": {
        "value": "${SERVICE_PROCESSES_IMAGE_NAME}"
      },
      "skipProcessesAcrPullRoleAssignment": {
        "value": "${SKIP_PROCESSES_ACR_PULL_ROLE_ASSIGNMENT=true}"
      },
      "enableMonitoring": {
        "value": "${ENABLE_MONITORING=true}"
      },
      "skipSqlSetup": {
        "value": "${SKIP_SQL_SETUP=false}"
      },
      "enableSqlDatabase": {
        "value": "${ENABLE_SQL_DATABASE=true}"
      },
      "enableVnetIntegration": {
        "value": "${ENABLE_VNET_INTEGRATION=false}"
      },
      "keyVaultName": {
        "value": "${KEY_VAULT_NAME=}"
      },
      "backendIdentityNameOverride": {
        "value": "${BACKEND_IDENTITY_NAME=}"
      },
      "frontendIdentityNameOverride": {
        "value": "${FRONTEND_IDENTITY_NAME=}"
      },
      "processesIdentityNameOverride": {
        "value": "${PROCESSES_IDENTITY_NAME=}"
      },
      "sqlAdminIdentityNameOverride": {
        "value": "${SQL_ADMIN_IDENTITY_NAME=}"
      },
      "sqlAdminLogin": {
        "value": "${SQL_ADMIN_LOGIN=sqladmin}"
      },
      "sqlAdminPassword": {
        "value": "${SQL_ADMIN_PASSWORD}"
      },
      "sqlAdGroupName": {
        "value": "${SQL_AD_GROUP_NAME=}"
      },
      "sqlAdGroupObjectId": {
        "value": "${SQL_AD_GROUP_OBJECT_ID=}"
      },
      "flywayValidateOnMigrate": {
        "value": "${FLYWAY_VALIDATE_ON_MIGRATE=true}"
      },
      "sqlDatabaseSku": {
        "value": "${SQL_DATABASE_SKU=Basic}"
      },
      "sqlDatabaseTier": {
        "value": "${SQL_DATABASE_TIER=Basic}"
      },
      "appConfigSku": {
        "value": "${APP_CONFIG_SKU=developer}"
      },
      "enableAadSso": {
        "value": "${ENABLE_AAD_SSO=true}"
      },
      "jwtIssuer": {
        "value": "${JWT_ISSUER=raptor-app}"
      },
      "jwtAccessTokenExpirationMinutes": {
        "value": "${JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=15}"
      },
      "jwtRefreshTokenExpirationDays": {
        "value": "${JWT_REFRESH_TOKEN_EXPIRATION_DAYS=7}"
      },
      "customDomainName": {
        "value": "${CUSTOM_DOMAIN_NAME=}"
      },
      "forceSqlSetupTag": {
        "value": "${FORCE_SQL_SETUP_TAG=}"
      }
    }
}
